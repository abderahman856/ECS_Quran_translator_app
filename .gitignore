# ─── Terraform ────────────────────────────────────────────────────────────────
*.tfvars                    # contains Cloudflare token, zone ID, secrets
!*.tfvars.example           # keep example files
**/.terraform/              # provider binaries
*.tfstate                   # contains sensitive resource outputs
*.tfstate.backup
.terraform.lock.hcl

# ─── Environment files ────────────────────────────────────────────────────────
.env
.env.local
.env.production
!.env.example               # keep example files

# ─── Node / JavaScript ────────────────────────────────────────────────────────
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Build output ─────────────────────────────────────────────────────────────
dist/
**/dist/
build/
**/build/

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# ─── IDE ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── AWS ──────────────────────────────────────────────────────────────────────
.aws/
# ─── Terraform provider binaries ──────────────────────────────────────────────
**/.terraform/

# ─── Bootstrap state ──────────────────────────────────────────────────────────
bootstrap/terraform.tfstate
bootstrap/terraform.tfstate.backup
