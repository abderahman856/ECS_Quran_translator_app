# envs/dev.tfvars.example
# Copy this file to dev.tfvars and fill in your real values
# NEVER commit dev.tfvars — only commit this example file

# ─── General ──────────────────────────────────────────────────────────────────
project_name = "your-app-name"
environment  = "dev"
aws_region   = "us-east-1"

# ─── Domain ───────────────────────────────────────────────────────────────────
domain_name = "dev.yourdomain.com"

# ─── ECS ──────────────────────────────────────────────────────────────────────
container_image = "YOUR_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/quran-app-backend:latest"
container_port  = 5000
cpu             = "256"
memory          = "512"
desired_count   = 1

# ─── VPC ──────────────────────────────────────────────────────────────────────
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.10.0/24", "10.0.11.0/24"]
availability_zones   = ["us-east-1a", "us-east-1b"]

# ─── ECR ──────────────────────────────────────────────────────────────────────
repository_names                = ["backend"]
image_tag_mutability            = "MUTABLE"
untainted_image_retention_count = 5

# ─── S3 ───────────────────────────────────────────────────────────────────────
bucket_name = "frontend"

# ─── CloudWatch ───────────────────────────────────────────────────────────────
log_retention_days = 7

# ─── Cloudflare ───────────────────────────────────────────────────────────────
cloudflare_zone_id   = "your-cloudflare-zone-id"
cloudflare_api_token = "your-cloudflare-api-token"